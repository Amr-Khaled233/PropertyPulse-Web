# Web environment — copy to apps/web/.env (only VITE_* vars are exposed to the client)

# Mock mode: when true (default) the app runs fully on seeded data — no backend or keys needed.
# Set to false to call the real server + Supabase.
VITE_USE_MOCK=true

VITE_API_URL=http://localhost:4000/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
