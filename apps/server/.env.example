# Server environment — copy to apps/server/.env
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Supabase (server uses the service-role key — keep secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Stripe (TEST mode). Leave empty to use the simulated gateway.
# Get a test secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# External data providers
PROPERTY_DATA_API_KEY=
RENTAL_MARKET_API_KEY=
ECONOMIC_DATA_API_KEY=
