# ============================================================
# PropertyPulse — Root Environment Example
# Copy to .env in each app and fill with real values.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — NEVER expose to client

# --- Google Gemini (AI) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- External data sources (real estate / market / economic) ---
PROPERTY_DATA_API_KEY=
RENTAL_MARKET_API_KEY=
ECONOMIC_DATA_API_KEY=
